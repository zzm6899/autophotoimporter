# Normalize line endings to LF in the repository to avoid CRLF/LF churn
# that produces phantom whole-file diffs on Windows checkouts.
* text=auto eol=lf

# Explicitly treat known text sources as LF.
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.svg  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Windows batch files must stay CRLF.
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.icns binary
*.mov  binary
*.mp4  binary
*.onnx binary
*.node binary
*.woff  binary
*.woff2 binary
