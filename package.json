{
  "name": "keptra",
  "productName": "Keptra",
  "version": "1.4.5",
  "description": "AI-assisted photo culling, import, and keeper selection",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "license:keypair": "node scripts/setup-license-keys.mjs",
    "license:generate": "node scripts/generate-license.mjs",
    "license:console": "node scripts/license-console.mjs",
    "update:publish": "node scripts/publish-update-release.mjs",
    "models": "node scripts/download-models.mjs",
    "models:publish": "node scripts/publish-models.mjs",
    "typecheck": "tsc --noEmit",
    "audit:runtime": "npm audit --omit=dev --audit-level=high",
    "verify": "npm run typecheck && npm test && npm run audit:runtime",
    "package:smoke": "node scripts/package-smoke.mjs",
    "visual:smoke": "node scripts/visual-smoke.mjs",
    "fixtures:smoke": "node scripts/generate-smoke-fixtures.mjs",
    "bench:smoke": "node scripts/bench-smoke.mjs",
    "release:manifest": "node scripts/release-manifest.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:sync-matrix": "node scripts/sync-support-matrix.mjs",
    "docs:check": "node scripts/check-doc-links.mjs"
  },
  "keywords": [],
  "engines": {
    "node": ">=20 <25"
  },
  "author": {
    "name": "Zac M",
    "email": "help@z2hs.au"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "40.8.5",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.7.0",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "basic-ftp": "^5.3.1",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "exifr": "7.1.3",
    "onnxruntime-node": "1.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
